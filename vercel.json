{
  "framework": null,
  "buildCommand": "python scripts/export_frontend.py",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/ocr/vps",
      "destination": "/api/ocr"
    },
    {
      "source": "/ocr/vps/:path*",
      "destination": "/api/ocr/:path*"
    },
    {
      "source": "/ocr/:path*",
      "destination": "/api/ocr/:path*"
    }
  ]
}
