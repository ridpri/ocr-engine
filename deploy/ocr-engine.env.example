PYTHONUNBUFFERED=1
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
PADDLE_PDX_ENABLE_MKLDNN_BYDEFAULT=0
FLAGS_use_mkldnn=0
FLAGS_use_onednn=0
FLAGS_enable_pir_api=0

# Set this before exposing the OCR API publicly.
OCR_API_KEY=change-this-long-random-secret

# Optional agent bridge. Leave empty for local PaddleOCR-only deployment.
# OCR_AGENT_COMMAND=
# OPENCLAW_OCR_WEBHOOK_URL=
# OPENCLAW_OCR_TOKEN=
# OCR_AGENT_TIMEOUT_SECONDS=60
